# Database (PostgreSQL)
# Local example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/taskzen?schema=public"
# Neon example (prefer pooler host for serverless/dev):
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/taskzen?schema=public"

# JWT secrets (generate strong random strings for production)
JWT_SECRET="replace-with-a-long-random-secret"
JWT_REFRESH_SECRET="replace-with-another-long-random-secret"

# Application URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google OAuth (server-side only — never expose GOOGLE_CLIENT_SECRET to the browser)
# Create an OAuth 2.0 Web client in Google Cloud Console.
# Authorized redirect URI must match exactly:
#   {NEXT_PUBLIC_APP_URL}/api/auth/google/callback
# Production example:
#   https://thetaskzen.vercel.app/api/auth/google/callback
# GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="your-client-secret"

# Password reset + task notification email delivery (Resend)
# EMAIL_PROVIDER="resend"
# RESEND_API_KEY="re_xxxxxxxx"
# EMAIL_FROM="Taskzen <onboarding@your-verified-domain.com>"
# For local verification scripts that capture outbound mail in-memory:
# EMAIL_PROVIDER="memory"

# Protects /api/cron/task-notifications (Vercel Cron sends Authorization: Bearer <CRON_SECRET>)
# CRON_SECRET="replace-with-a-long-random-secret"

# Administrator access (server-side only — email of the Taskzen account with admin rights)
# ADMIN_USER_EMAIL="your-account@example.com"

# Required for local DB-writing verification scripts (creates temporary @example.com users).
# Never set this in production hosting. Prefer a dedicated test database when possible.
# TASKZEN_ALLOW_DB_TESTS=1

# Optional: profile photo uploads (Phase 2+)
# UPLOADTHING_TOKEN=""
# CLOUDINARY_URL=""
