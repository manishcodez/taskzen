# Database (PostgreSQL)
# Local example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/taskzen?schema=public"
# Neon example (prefer pooler host for serverless/dev):
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/taskzen?schema=public"

# JWT secrets (generate strong random strings for production)
JWT_SECRET="replace-with-a-long-random-secret"
JWT_REFRESH_SECRET="replace-with-another-long-random-secret"

# Application URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: profile photo uploads (Phase 2+)
# UPLOADTHING_TOKEN=""
# CLOUDINARY_URL=""
