generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TaskType {
  ASSIGNMENT
  HOMEWORK
  PROJECT
  EXAM_PREPARATION
  PRACTICAL
  PRESENTATION
  READING
  PERSONAL_STUDY
  OTHER
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum EmailNotificationType {
  DEADLINE_REMINDER
  OVERDUE
}

model User {
  id                         String   @id @default(uuid()) @db.Uuid
  email                      String   @unique @db.VarChar(255)
  /// Null for Google-only accounts that have never set a password.
  passwordHash               String?  @map("password_hash") @db.VarChar(255)
  /// Bumped on password change/reset to invalidate existing JWTs.
  tokenVersion               Int      @default(0) @map("token_version")
  name                       String?  @db.VarChar(100)
  profilePhotoUrl            String?  @map("profile_photo_url")
  course                     String?  @db.VarChar(100)
  college                    String?  @db.VarChar(150)
  semester                   String?  @db.VarChar(50)
  academicYear               String?  @map("academic_year") @db.VarChar(20)
  emailDeadlineReminders     Boolean  @default(true) @map("email_deadline_reminders")
  emailOverdueNotifications  Boolean  @default(true) @map("email_overdue_notifications")
  createdAt                  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  subjects                    Subject[]
  tasks                       Task[]
  passwordResetTokens         PasswordResetToken[]
  emailNotificationDeliveries EmailNotificationDelivery[]
  oauthAccounts               OAuthAccount[]

  @@map("users")
}

model OAuthAccount {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  provider          String   @db.VarChar(32)
  providerAccountId String   @map("provider_account_id") @db.VarChar(255)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@unique([userId, provider])
  @@index([userId])
  @@map("oauth_accounts")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  /// SHA-256 hex of the raw token emailed to the user — never store the raw value.
  tokenHash String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Subject {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  name        String   @db.VarChar(100)
  code        String?  @db.VarChar(30)
  color       String   @default("#6366f1") @db.VarChar(7)
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@unique([userId, name])
  @@index([userId])
  @@map("subjects")
}

model Task {
  id                   String       @id @default(uuid()) @db.Uuid
  userId               String       @map("user_id") @db.Uuid
  subjectId            String       @map("subject_id") @db.Uuid
  title                String       @db.VarChar(200)
  description          String?
  type                 TaskType     @default(OTHER)
  priority             TaskPriority @default(MEDIUM)
  status               TaskStatus   @default(NOT_STARTED)
  dueDate              DateTime?    @map("due_date") @db.Timestamptz(6)
  estimatedTimeMinutes Int?         @map("estimated_time_minutes")
  notes                String?
  completedAt          DateTime?    @map("completed_at") @db.Timestamptz(6)
  createdAt            DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  emailNotificationDeliveries EmailNotificationDelivery[]

  @@index([userId, dueDate])
  @@index([userId, status])
  @@index([userId, priority])
  @@index([userId, subjectId])
  @@index([userId, createdAt])
  @@index([dueDate, status])
  @@map("tasks")
}

model EmailNotificationDelivery {
  id          String                @id @default(uuid()) @db.Uuid
  userId      String                @map("user_id") @db.Uuid
  taskId      String                @map("task_id") @db.Uuid
  type        EmailNotificationType
  /// ISO due-date fingerprint so a changed deadline can notify again.
  dueDateKey  String                @map("due_date_key") @db.VarChar(40)
  sentAt      DateTime              @default(now()) @map("sent_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, type, dueDateKey])
  @@index([userId, type])
  @@index([sentAt])
  @@map("email_notification_deliveries")
}
